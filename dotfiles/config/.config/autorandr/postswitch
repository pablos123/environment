#!/usr/bin/env bash

# autorandr postswitch hook: applies i3 workspace layout after a profile
# switch, then reloads i3 so bars re-init per monitor. Runs for every
# profile; when only one output is active, primary == nonprimary and the
# workspace moves are harmless no-ops.

set -Eeuo pipefail

command -v i3-msg >/dev/null || exit 0
command -v jq >/dev/null || exit 0

function get_current_workspace {
    i3-msg -t get_workspaces | jq --raw-output '.[] | select(.focused) | .name'
}

function move_workspaces_to_primary {
    local current_workspace
    current_workspace="$(get_current_workspace)"

    local -a workspaces=()
    mapfile -t workspaces < <(i3-msg -t get_workspaces | jq --raw-output '.[].name')

    local w
    for w in "${workspaces[@]}"; do
        if [[ "${w}" == "0" ]]; then
            i3-msg workspace "${w}"
            i3-msg move workspace to output nonprimary
            continue
        fi

        i3-msg workspace "${w}"
        i3-msg move workspace to output primary
    done

    i3-msg workspace "${current_workspace}"
}

move_workspaces_to_primary >/dev/null
i3-msg reload >/dev/null 2>&1

wallpaper_config="${HOME}/environment/bin/wallpaper-config"
if [[ -x "${wallpaper_config}" ]]; then
    "${wallpaper_config}"
fi
