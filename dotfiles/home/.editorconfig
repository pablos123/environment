root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# [[bash]] is shfmt-specific; matches any file shfmt detects as bash
# (extension or shebang). Other editorconfig consumers ignore it.
[[bash]]
switch_case_indent = true

[*.{c,h,html,css,yml,yaml}]
indent_size = 2
