#!/usr/bin/env bash

# Bootstrap setup

set -Eeuo pipefail

declare -r ENVIRONMENT_REPO_URL="git@github.com:pablos123/environment.git"
declare -r WALLPAPERS_REPO_URL="git@github.com:pablos123/wallpapers.git"
declare -r ENVIRONMENT_DIR="${HOME}/environment"
declare -r INSTALLERS_DIR="${ENVIRONMENT_DIR}/lib/installers"
declare -r RELOAD_SCRIPT="${ENVIRONMENT_DIR}/bin/reload-environment"

declare -ra NEEDED_DIRECTORIES=(
    "${HOME}/repos"
    "${HOME}/.base_repos"
    "${HOME}/bin"
    "${HOME}/.local/bin"
    "${HOME}/playground"
    "${HOME}/images/wallpapers"
    "${HOME}/images/screenshots"
)

function log {
    printf '\033[1;32m==>\033[0m %s\n' "${1:-}" >&2
}

function warn {
    # shellcheck disable=SC2317  # bootstrap warn; overridden after source but kept for pre-clone error paths
    printf '\033[1;33m[WARN]\033[0m %s\n' "${1:-}" >&2
}

function die {
    printf '\033[1;31m[ERROR]\033[0m %s\n' "${1:-}" >&2
    exit 1
}

function main {
    if [[ ! -f "${HOME}/.ssh/id_rsa.pub" ]]; then
        die "Missing SSH public key at ~/.ssh/id_rsa.pub"
    fi

    if [[ ! -d "${ENVIRONMENT_DIR}" ]]; then
        log "Cloning environment repository"
        git clone --quiet "${ENVIRONMENT_REPO_URL}" "${ENVIRONMENT_DIR}"
    else
        log "Updating environment repository"
        git -C "${ENVIRONMENT_DIR}" pull --ff-only --quiet
    fi

    # Source helpers now that environment repo exists
    source "${ENVIRONMENT_DIR}/lib/helpers.bash"

    git_clone_pull_repo "${WALLPAPERS_REPO_URL}" "${HOME}/repos/wallpapers" false

    log "Ensuring base directory structure"
    mkdir --parents "${NEEDED_DIRECTORIES[@]}" >/dev/null

    log "Asking for sudo password"
    sudo --validate

    if [[ ! -d "${INSTALLERS_DIR}" ]]; then
        die "Installers directory not found: ${INSTALLERS_DIR}"
    fi

    local -a installers=()
    shopt -s nullglob
    installers=("${INSTALLERS_DIR}"/*.bash)
    shopt -u nullglob

    if ((${#installers[@]} > 0)); then
        log "Running installers"
        local installer
        for installer in "${installers[@]}"; do
            log
            log "=== Executing: ${installer##*/} ==="
            "${installer}"
        done
    fi

    log "Running apt autopurge"
    sudo apt autopurge --yes

    if command -v flatpak >/dev/null; then
        log "Updating Flatpak packages"
        flatpak update --assumeyes
    fi

    if [[ -x "${RELOAD_SCRIPT}" ]]; then
        log "Reloading environment"
        "${RELOAD_SCRIPT}" >/dev/null
    else
        warn "${RELOAD_SCRIPT} script not found or not executable"
    fi

    log
    log "Setup completed successfully"
    warn "A reboot is recommended"
}

main "$@"
