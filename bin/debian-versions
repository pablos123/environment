#!/usr/bin/env bash

# Debian versions

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands curl pandoc column sed

declare -r RELEASES_URL='https://www.debian.org/releases/'

declare -ra HEADER_NAMES=(
    "Version"
    "Code Name"
    "Release Date"
    "End of Life"
    "End of LTS"
    "End of ELTS"
    "Status"
)

function get_headers {
    local result=""

    local header_name
    for header_name in "${HEADER_NAMES[@]}"; do
        result+="\e[1;35m${header_name}\e[0m,"
    done

    printf '%b\n' "${result}"
}

function main {
    local curl_response_md release_table_md sanitized_table old_ifs

    old_ifs="${IFS}"
    IFS=$'\n'

    curl_response_md="$(pandoc --from html --to markdown <(curl "${RELEASES_URL}" 2>/dev/null))"

    release_table_md="$(
        sed --regexp-extended --quiet '
            /^\s+Version\s+Code Name\s+Release Date\s+End of Life\s+/,/^$/ {p; /^$/q};
        ' <<<"${curl_response_md}"
    )"

    sanitized_table="$(
        sed --regexp-extended '
            s/^\s+//;
            /^$/d;
            s/.*Version.*//;
            s/.*-----.*//;
            s/\(.*\/\)//;
            s/\s{2,}/\t/g;
        ' <<<"${release_table_md}"
    )"

    column --table --separator $'\t' --table-columns "$(get_headers)" <<<"${sanitized_table}"

    printf '\n%s\n\n' "${RELEASES_URL}"

    IFS="${old_ifs}"
}

main "$@"
