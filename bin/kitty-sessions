#!/usr/bin/env bash

# Kitty session picker

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands kitty rofi zenity grep

declare -r USER_SESSIONS_DIR="${HOME}/.config/kitty/sessions"
declare -r WORK_SESSIONS_DIR="${HOME}/repos/work/kitty-sessions"
declare -r ASKPASS_HELPER="${HOME}/environment/bin/sudo-askpass"

declare -A SESSIONS

function collect_sessions {
    local label dir name key
    local -a entries=("user:${USER_SESSIONS_DIR}" "work:${WORK_SESSIONS_DIR}")

    local entry file
    for entry in "${entries[@]}"; do
        label="${entry%%:*}"
        dir="${entry#*:}"
        if [[ ! -d "${dir}" ]]; then
            continue
        fi
        for file in "${dir}"/*.conf; do
            if [[ ! -f "${file}" ]]; then
                continue
            fi
            name="${file##*/}"
            name="${name%.conf}"
            key="${label}:${name}"
            SESSIONS["${key}"]="${file}"
        done
    done
}

function pick_session {
    printf '%s\n' "${!SESSIONS[@]}" | sort | rofi -dmenu -i -p 'session'
}

function prompt_sudo_password {
    local password

    if ! password="$(zenity --password)"; then
        return 1
    fi

    if ! printf '%s\n' "${password}" | sudo --stdin --validate 2>/dev/null; then
        die "Bad password. Aborting."
    fi

    printf '%s' "${password}"
}

function main {
    local choice session

    collect_sessions

    if ((${#SESSIONS[@]} == 0)); then
        die "no sessions found"
    fi

    if ! choice="$(pick_session)"; then
        return 0
    fi

    if [[ -z "${choice}" ]]; then
        return 0
    fi

    session="${SESSIONS[${choice}]:-}"
    if [[ ! -f "${session}" ]]; then
        die "session file not found: ${choice}"
    fi

    if grep --quiet --extended-regexp '\bsudo +-A\b' "${session}"; then
        if [[ ! -x "${ASKPASS_HELPER}" ]]; then
            die "askpass helper missing: ${ASKPASS_HELPER}"
        fi

        local sudo_password
        if ! sudo_password="$(prompt_sudo_password)"; then
            return 0
        fi

        export SUDO_PASSWORD="${sudo_password}"
        export SUDO_ASKPASS="${ASKPASS_HELPER}"
    fi

    exec kitty --session "${session}"
}

main "$@"
