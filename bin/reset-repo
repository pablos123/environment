#!/usr/bin/env bash

# Reset repository to a single commit

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands git

function main {
    local branch="${1:-}"
    local message="${2:-reset commit}"

    if [[ -z "${branch}" || ("${branch}" != "main" && "${branch}" != "master") ]]; then
        die "Usage: reset-repo 'main|master' ['<commit_message>']"
    fi

    log "Resetting repository to single commit on ${branch}"

    git checkout --orphan latest_branch
    git add --all
    git commit --message="${message}"
    git branch --delete --force "${branch}"
    git branch --move "${branch}"
    git push --force origin "${branch}"
    git branch --set-upstream-to=origin/"${branch}"

    log "Repository reset complete"
}

main "$@"
