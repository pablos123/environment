#!/usr/bin/env bash

# First-boot post-install setup

set -Eeuo pipefail

source "/home/pab/environment/lib/helpers.bash"

declare -r TARGET_USER="pab"
declare -r MOUNT_BASE="/media/${TARGET_USER}"
declare -r MOUNT_POINT="${MOUNT_BASE}/usb1"

function require_root {
    if ((EUID != 0)); then
        die "Run this script as root"
    fi
}

function main {
    require_root

    log "Starting Debian headless post-install setup"

    log "Asking for /dev/sdxn"

    local sdxn
    read -r -p "In which device partition is the passwords.kdbx file?: (sdxn) " sdxn

    if [[ -z "${sdxn}" ]]; then
        die "Empty sdxn"
    fi

    if [[ ! -e "/dev/${sdxn}" ]]; then
        die "/dev/${sdxn} does not exist"
    fi

    log "Asking if it is work"

    local is_work
    read -r -p "Is this setup for work?: (yes/no) " is_work

    log "Asking for keepassxc vault password"

    local vault_pass
    read -rs -p "Insert keepassxc vault password: " vault_pass

    log "Removing cdrom entries from APT sources"

    if ! sed --in-place '/^deb cdrom:/d' /etc/apt/sources.list; then
        :
    fi

    if [[ -d /etc/apt/sources.list.d ]]; then
        if ! sed --in-place '/^deb cdrom:/d' /etc/apt/sources.list.d/*.list >/dev/null; then
            :
        fi
    fi

    log "Updating package lists"
    apt update >/dev/null

    log "Installing NetworkManager"
    apt install --yes network-manager >/dev/null

    log "Disabling legacy ifupdown networking"
    rm --force /etc/network/interfaces

    if ! systemctl disable networking.service >/dev/null 2>&1; then
        :
    fi
    if ! systemctl stop networking.service >/dev/null 2>&1; then
        :
    fi

    if ! apt purge --yes ifupdown >/dev/null; then
        :
    fi

    log "Enabling NetworkManager"
    systemctl enable NetworkManager >/dev/null
    systemctl restart NetworkManager >/dev/null

    log "Waiting for DNS resolution to come up"
    local -i i
    for ((i = 1; i <= 30; i++)); do
        if getent hosts google.com >/dev/null 2>&1; then
            log "DNS is working"
            break
        fi
        if ((i == 30)); then
            die "DNS resolution failed after 30 seconds"
        fi
        sleep 1
    done

    log "Installing base packages"
    apt install --yes \
        git \
        sudo \
        ntfs-3g \
        rfkill \
        curl \
        keepassxc \
        fwupd \
        >/dev/null

    log "Granting sudo access to ${TARGET_USER}"
    usermod --append --groups sudo "${TARGET_USER}" >/dev/null

    log "Creating mount directories"
    mkdir --parents \
        "${MOUNT_BASE}/usb1" \
        "${MOUNT_BASE}/usb2" \
        "${MOUNT_BASE}/usb3" \
        >/dev/null

    log "Removing apt unstable cli interface warning"
    printf '%s\n' "Apt::Cmd::Disable-Script-Warning true;" | tee /etc/apt/apt.conf.d/90disablescriptwarning

    log "Creating /home/${TARGET_USER}/.ssh directory "
    mkdir --parents "/home/${TARGET_USER}/.ssh"

    if [[ -n "$(ls -A "${MOUNT_POINT}")" ]]; then
        die "${MOUNT_POINT} directory not empty"
    fi

    log "Mounting usb"
    mount "/dev/${sdxn}" "${MOUNT_POINT}"

    log "Reading vault passwords"
    if [[ "${is_work}" == "yes" ]]; then
        keepassxc-cli show --quiet --attributes notes "${MOUNT_POINT}/passwords.kdbx" 'SSH Work Priv' <<<"${vault_pass}" >"/home/${TARGET_USER}/.ssh/id_rsa"
        keepassxc-cli show --quiet --attributes notes "${MOUNT_POINT}/passwords.kdbx" 'SSH Work Public' <<<"${vault_pass}" >"/home/${TARGET_USER}/.ssh/id_rsa.pub"
    else
        keepassxc-cli show --quiet --attributes notes "${MOUNT_POINT}/passwords.kdbx" 'SSH Main Priv' <<<"${vault_pass}" >"/home/${TARGET_USER}/.ssh/id_rsa"
        keepassxc-cli show --quiet --attributes notes "${MOUNT_POINT}/passwords.kdbx" 'SSH Main Public' <<<"${vault_pass}" >"/home/${TARGET_USER}/.ssh/id_rsa.pub"
    fi

    chmod 0600 "/home/${TARGET_USER}/.ssh/id_rsa"
    chmod 0644 "/home/${TARGET_USER}/.ssh/id_rsa.pub"

    chown --recursive "${TARGET_USER}:${TARGET_USER}" "/home/${TARGET_USER}/.ssh/"

    log "Unmounting usb"
    umount "${MOUNT_POINT}"

    log "Configuring correct timezone"
    timedatectl set-timezone America/Argentina/Buenos_Aires

    log "Disabling bell system-wide"

    cat >/etc/inputrc <<'INPUTRC'
$include /etc/inputrc.dpkg-dist
set bell-style none
INPUTRC

    printf '%s\n' "blacklist pcspkr" >/etc/modprobe.d/nobeep.conf
    printf '%s\n' "blacklist snd_pcsp" >>/etc/modprobe.d/nobeep.conf

    log "Configuring EU keyboard layout"

    cat >/etc/default/keyboard <<'KBEOF'
XKBMODEL="pc105"
XKBLAYOUT="eu"
XKBVARIANT=""
XKBOPTIONS=""
BACKSPACE="guess"
KBEOF

    if ! setupcon --force 2>/dev/null; then
        :
    fi

    log "Configuring keyd for key remapping"

    mkdir --parents /etc/keyd

    cat >/etc/keyd/default.conf <<'KDEOF'
[ids]
*

[main]
capslock = escape
escape = capslock
KDEOF

    cat >/etc/keyd/logitech-bolt.conf <<'KDEOF'
[ids]
*Logi Bolt Receiver*

[main]
leftalt = layer(meta)
leftmeta = layer(alt)
rightalt = layer(control)
rightmeta = layer(altgr)
KDEOF

    systemctl enable keyd

    log "Configuring PAM to auto-unlock GNOME Keyring on login"

    if ! grep --quiet 'pam_gnome_keyring.so' /etc/pam.d/login; then
        sed --in-place '/@include common-auth/a auth       optional   pam_gnome_keyring.so' /etc/pam.d/login
        sed --in-place '/@include common-session/a session    optional   pam_gnome_keyring.so auto_start' /etc/pam.d/login
    fi

    log "Checking for firmware updates"
    fwupdmgr --force --assume-yes refresh
    fwupdmgr --force --assume-yes get-updates
    fwupdmgr --force --assume-yes update

    log "Post-install setup complete"
    warn "Consider removing the usb"
    warn "Exit the root session and enter as ${TARGET_USER} to bootsrap the setup."
}

main "$@"
