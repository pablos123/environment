#!/usr/bin/env bash

# Claude status check

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands curl notify-send xdg-open

declare -r URL="https://status.claude.com/"

function main {
    local content
    if ! content="$(curl --silent --fail --max-time 10 "${URL}")"; then
        die "Failed to fetch ${URL}"
    fi

    local unresolved
    unresolved="$(sed -n '/<div class="unresolved-incidents">/,/<div class="components-section">/p' <<<"${content}")"

    local title=""
    if ! title="$(grep --only-matching --perl-regexp 'actual-title[^>]*>\K[^<]+' <<<"${unresolved}" | head --lines=1)"; then
        title=""
    fi

    if [[ -z "${title}" ]]; then
        return 0
    fi

    local status=""
    if ! status="$(grep --only-matching --perl-regexp '<strong>\K[^<]+' <<<"${unresolved}" | head --lines=1)"; then
        status=""
    fi

    local message=""
    if ! message="$(grep --only-matching --perl-regexp 'whitespace-pre-wrap">\K[^<]+' <<<"${unresolved}" | head --lines=1)"; then
        message=""
    fi

    local action
    action="$(notify-send \
        --urgency=critical \
        --app-name="Claude Status" \
        --wait \
        --action="default=Open status page" \
        "${title}" \
        "[${status}] ${message}")"

    if [[ "${action}" == "default" ]]; then
        xdg-open "${URL}"
    fi
}

main "$@"
