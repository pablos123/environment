#!/usr/bin/env bash

# Dim screen

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands redshift notify-send

declare -ri DIM_COLOR_TEMP=4000
declare -r DIM_BRIGHTNESS=0.6

function main {
    local mode

    mode="${1:-}"

    if [[ "${mode}" == "night" ]]; then
        redshift -O "${DIM_COLOR_TEMP}" -b "${DIM_BRIGHTNESS}" >/dev/null 2>&1
    else
        redshift -x >/dev/null 2>&1
    fi

    notify-send "Brightness adjusted!"
}

main "$@"
