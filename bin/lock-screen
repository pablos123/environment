#!/usr/bin/env bash

# Lock screen

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands scrot convert i3lock

TMP_FILE="$(mktemp --suffix=.png)"
TMP_FILE_BLUR="$(mktemp --suffix=.png)"
declare -r TMP_FILE TMP_FILE_BLUR

function cleanup {
    rm --force "${TMP_FILE}" "${TMP_FILE_BLUR}"
}

function main {
    scrot --overwrite "${TMP_FILE}"
    convert -blur 0x20 "${TMP_FILE}" "${TMP_FILE_BLUR}"
    i3lock --no-unlock-indicator --nofork --ignore-empty-password --image "${TMP_FILE_BLUR}"
}

main "$@"
