#!/usr/bin/env bash

# Open terminal based on memory

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands free awk

declare -ri MEMORY_THRESHOLD_KB=10000000

function main {
    local -i total_memory
    total_memory="$(free --total | awk '/^Mem:/ {print $2}')"

    if ((total_memory > MEMORY_THRESHOLD_KB)); then
        exec kitty
    fi
    exec /usr/local/bin/st
}

main "$@"
