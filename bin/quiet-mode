#!/usr/bin/env bash

# Quiet mode

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands dunstctl yad

declare -r QUIET_MODE_ICON="${HOME}/environment/assets/nonotif.png"

function main {
    local paused

    dunstctl set-paused toggle

    paused="$(dunstctl is-paused)"

    if [[ "${paused}" == "true" ]]; then
        bash -c "exec -a quiet_mode_icon yad --notification --image='${QUIET_MODE_ICON}' --listen --text='Quiet mode on' --no-middle &"
    else
        if ! pkill --full quiet_mode_icon; then
            :
        fi
    fi
}

main "$@"
