#!/usr/bin/env bash

# Shutdown with GUI password prompt

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands zenity sudo

function main {
    local sudo_password

    if ! sudo_password="$(zenity --password)"; then
        return 0
    fi

    if ! printf '%s\n' "${sudo_password}" | sudo --stdin --validate 2>/dev/null; then
        die "Bad password. Aborting."
    fi

    sudo shutdown now
}

main "$@"
