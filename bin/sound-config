#!/usr/bin/env bash

# Sound configuration applet

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands pavucontrol xdotool

declare -ri PAVUCONTROL_WIDTH=600
declare -ri PAVUCONTROL_HEIGHT=400

function pavu_visible {
    if xdotool search --onlyvisible --class "pavucontrol" 2>/dev/null; then
        return 0
    fi
    if xdotool search --onlyvisible --class "Pavucontrol" 2>/dev/null; then
        return 0
    fi
    return 1
}

function close_pavu {
    if ! xdotool search --onlyvisible --class "pavucontrol" windowclose 2>/dev/null; then
        if ! xdotool search --onlyvisible --class "Pavucontrol" windowclose 2>/dev/null; then
            :
        fi
    fi
}

function main {
    if pavu_visible; then
        close_pavu
        return 0
    fi

    pavucontrol -t 3 &
    disown

    while ! pavu_visible; do
        sleep 0.3
    done

    local -i pos_x
    local -i pos_y
    read -r pos_x pos_y < <(calculate_applet_position "${PAVUCONTROL_WIDTH}" "${PAVUCONTROL_HEIGHT}")

    if ! xdotool search --onlyvisible --class "pavucontrol" \
        windowsize "${PAVUCONTROL_WIDTH}" "${PAVUCONTROL_HEIGHT}" \
        windowmove "${pos_x}" "${pos_y}" 2>/dev/null; then
        if ! xdotool search --onlyvisible --class "Pavucontrol" \
            windowsize "${PAVUCONTROL_WIDTH}" "${PAVUCONTROL_HEIGHT}" \
            windowmove "${pos_x}" "${pos_y}" 2>/dev/null; then
            :
        fi
    fi
}

main "$@"
