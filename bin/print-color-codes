#!/usr/bin/env bash

# Print color codes

set -Eeuo pipefail

function main {
    local -i x
    for x in {0..8}; do
        printf '\e[%dm\\e[%dm\e[0m \n' "${x}" "${x}"
    done

    local -i i
    for x in {0..8}; do
        for i in {30..37}; do
            printf '\e[%d;%dm\\e[%d;%dm\e[0m ' "${x}" "${i}" "${x}" "${i}"
        done
        printf '\n'
    done

    local -i a
    for x in {0..8}; do
        for i in {30..37}; do
            for a in {40..47}; do
                printf '\e[%d;%d;%dm\\e[%d;%d;%dm\e[0m ' "${x}" "${i}" "${a}" "${x}" "${i}" "${a}"
            done
            printf '\n'
        done
    done

    printf '\e[0m'
}

main "$@"
