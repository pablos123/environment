#!/usr/bin/env bash

set -Eeuo pipefail
shopt -s inherit_errexit

source "${HOME}/environment/lib/helpers.bash"

require_commands google-chrome

function main {
    exec google-chrome \
        --enable-blink-features=MiddleClickAutoscroll \
        --enable-features=EnableNativeNotifications \
        "$@"
}

main "$@"
