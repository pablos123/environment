#!/usr/bin/env bash

# Monitor hotplug handler

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands jq xrandr i3-msg

declare -r TMP_CONNECTED_FILE='/tmp/monitors_connected'

function get_current_workspace {
    local name_focused
    local -a workspaces=()

    mapfile -t workspaces < <(i3-msg -t get_workspaces | jq --raw-output '.[] | "\(.name)::\(.focused)"')

    local w
    for w in "${workspaces[@]}"; do
        mapfile -t name_focused < <(printf '%s' "${w//::/\\n}")
        if [[ "${name_focused[1]}" == "true" ]]; then
            printf '%s\n' "${name_focused[0]}"
            break
        fi
    done
}

function move_workspaces_to_primary {
    local current_workspace
    local -a workspaces=()

    current_workspace="$(get_current_workspace)"

    mapfile -t workspaces < <(i3-msg -t get_workspaces | jq --raw-output '.[].name')

    local w
    for w in "${workspaces[@]}"; do
        if [[ "${w}" == "0" ]]; then
            i3-msg workspace "${w}"
            i3-msg move workspace to output nonprimary
            continue
        fi

        i3-msg workspace "${w}"
        i3-msg move workspace to output primary
    done

    i3-msg workspace "${current_workspace}"
}

function disable_phantom_outputs {
    local -a outputs=()

    mapfile -t outputs < <(xrandr | awk '/ disconnected [0-9]+x[0-9]+\+/ {print $1}')

    local output
    for output in "${outputs[@]}"; do
        xrandr --output "${output}" --off
    done
}

function configure_monitors {
    local -n monitors_ref="${1}"

    disable_phantom_outputs

    # Notebook
    if [[ "${monitors_ref[*]}" =~ "eDP-1" ]]; then
        if [[ "${monitors_ref[*]}" =~ "HDMI-1" ]]; then
            xrandr --output "HDMI-1" --primary --auto --left-of "eDP-1"
        else
            xrandr --output "eDP-1" --primary --auto
        fi
    # Notebook lid closed, external monitor only
    elif [[ "${monitors_ref[*]}" =~ "HDMI-1" ]]; then
        xrandr --output "HDMI-1" --primary --auto
    else
        i3-nagbar -m 'Monitors configuration not recognized.' -t warning
    fi

    move_workspaces_to_primary >/dev/null 2>&1
}

function main {
    local had_previous_config
    local -a monitors=() monitors_stable=()

    mapfile -t monitors < <(xrandr | grep " connected" | awk '{print $1}')

    if [[ -f "${TMP_CONNECTED_FILE}" ]] && [[ "${monitors[*]}" == "$(cat "${TMP_CONNECTED_FILE}")" ]]; then
        exit 0
    fi

    # Wait and re-check to avoid reacting to brief disconnects
    # (e.g. monitor powering off momentarily reports as disconnected)
    sleep 3
    mapfile -t monitors_stable < <(xrandr | grep " connected" | awk '{print $1}')

    if [[ -f "${TMP_CONNECTED_FILE}" ]] && [[ "${monitors_stable[*]}" == "$(cat "${TMP_CONNECTED_FILE}")" ]]; then
        exit 0
    fi

    monitors=("${monitors_stable[@]}")

    if [[ -f "${TMP_CONNECTED_FILE}" ]]; then
        had_previous_config=true
    else
        had_previous_config=false
    fi

    configure_monitors monitors
    printf '%s' "${monitors[*]}" >"${TMP_CONNECTED_FILE}"

    # Only reload i3 on actual monitor hotplug, not on first boot
    # when i3 just started and monitors are already correctly configured.
    if [[ "${had_previous_config}" == true ]]; then
        i3-msg reload >/dev/null 2>&1
    fi
}

main "$@"
