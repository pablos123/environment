#!/usr/bin/env bash

set -Eeuo pipefail
shopt -s inherit_errexit

source "${HOME}/environment/lib/helpers.bash"

require_commands hsetroot find

declare -r CONFIG_FILE="${HOME}/.wallpaper_config"
declare -ra ALLOWED_FORMS=(cover center fill full tile extend)

function main {
    local type="default"
    local form="cover"

    if [[ -r "${CONFIG_FILE}" ]]; then
        # shellcheck source=/dev/null
        source "${CONFIG_FILE}"
    fi
    form="${form:-cover}"
    type="${type:-default}"

    local allowed
    local -i is_valid=0
    for allowed in "${ALLOWED_FORMS[@]}"; do
        if [[ "${form}" == "${allowed}" ]]; then
            is_valid=1
            break
        fi
    done
    if ((is_valid == 0)); then
        warn "unknown wallpaper form '${form}', falling back to 'cover'"
        form="cover"
    fi

    local wallpapers_dir="${HOME}/images/wallpapers/${type}/"
    if [[ ! -d "${wallpapers_dir}" ]]; then
        wallpapers_dir="${HOME}/images/wallpapers/default/"
    fi

    local -a wallpapers
    mapfile -t wallpapers < <(find "${wallpapers_dir}" -maxdepth 1 -type f -name '*.png')

    local -i items_count="${#wallpapers[@]}"
    ((items_count)) || return 0

    local -i random_index=$((RANDOM % items_count))
    local wallpaper="${wallpapers[random_index]}"
    hsetroot "-${form}" "${wallpaper}" >/dev/null 2>&1
}

main "$@"
