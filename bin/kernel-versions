#!/usr/bin/env bash

# Kernel versions

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands curl jq column

declare -r KERNEL_ORG_URL='https://www.kernel.org'

TMP_FILE="$(mktemp --suffix=.json)"
declare -r TMP_FILE

function cleanup {
    rm --force "${TMP_FILE}"
}

function main {
    local latest_stable columns

    curl --no-progress-meter --output "${TMP_FILE}" "${KERNEL_ORG_URL}/releases.json"

    latest_stable="$(jq --raw-output --monochrome-output .latest_stable.version "${TMP_FILE}")"
    printf '\n\e[1;32mLatest Stable:\e[0m \e[1;33m%s\e[0m\n\n' "${latest_stable}"

    columns="$(jq --raw-output --monochrome-output '.releases | map(.moniker + "  " + .version + "  " + .released.isodate) | .[]' "${TMP_FILE}")"

    printf '\e[4;35mMoniker\e[0m  \e[4;35mVersion\e[0m  \e[4;35mDate\e[0m\n%s\n' "${columns}" | column --table
    printf '\n%s\n\n' "${KERNEL_ORG_URL}"
}

main "$@"
