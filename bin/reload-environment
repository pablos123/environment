#!/usr/bin/env bash

# Reload environment

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands git stow systemctl gsettings fc-cache i3-msg

declare -r ENVIRONMENT_DIR="${HOME}/environment"
declare -r DOTFILES_DIR="${HOME}/.dotfiles_stow"

declare -ra FILES_TO_REMOVE=(
    "${DOTFILES_DIR}"
    "${HOME}/.bashrc"
    "${HOME}/.profile"
    "${HOME}/.xinitrc"
    "${HOME}/.xprofile"
    "${HOME}/.Xresources"
    "${HOME}/.gtkrc-2.0"
    "${HOME}/.config/gtk-3.0"
)

declare -ra CACHE_FILES=(
    "${HOME}/rofi-3.runcache"
    "${HOME}/.cache/dmenu_run"
    "${HOME}/dmenu_cache"
)

function main {
    rm --recursive --force "${FILES_TO_REMOVE[@]}"

    git -C "${ENVIRONMENT_DIR}" pull --ff-only >/dev/null

    cp --recursive "${ENVIRONMENT_DIR}/dotfiles" "${DOTFILES_DIR}"

    if ! cd "${DOTFILES_DIR}"; then
        die "could not cd into ${DOTFILES_DIR}"
    fi
    stow --target="${HOME}" --restow -- */
    systemctl --user daemon-reload

    local unit
    for unit in "${ENVIRONMENT_DIR}/dotfiles/config/.config/systemd/user"/*; do
        if grep --quiet '^\[Install\]' "${unit}"; then
            systemctl --user enable "${unit##*/}" &>>/dev/null
        fi
    done

    rm --force "${CACHE_FILES[@]}"

    # Prefer the dark GTK theme for apps like zenity. libglib2.0-bin
    # provides gsettings; it ships with Debian by default.
    gsettings set org.gnome.desktop.interface gtk-theme 'Adwaita-dark'
    gsettings set org.gnome.desktop.interface icon-theme 'Papirus-Dark'
    gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'

    if ! {
        fc-cache --really-force
        systemctl --user restart picom.service dunst.service
        quit_and_wait "polybar-msg cmd quit" polybar
        i3-msg restart
    } >/dev/null; then
        :
    fi
}

main "$@"
