#!/usr/bin/env bash

# Clean urgent flag

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands wmctrl awk

function main {
    local -a windows

    mapfile -t windows < <(wmctrl -l | awk '{print $1}')

    local win
    for win in "${windows[@]}"; do
        wmctrl -i -r "${win}" -b remove,demands_attention
    done
}

main "$@"
