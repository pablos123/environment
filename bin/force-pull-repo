#!/usr/bin/env bash

set -Eeuo pipefail
shopt -s inherit_errexit

source "${HOME}/environment/lib/helpers.bash"

require_commands git

function main {
    local -i skip_confirm=0
    if [[ "${1:-}" == "-y" ]]; then
        skip_confirm=1
        shift
    fi

    local branch="${1:-}"
    if [[ -z "${branch}" || ("${branch}" != "main" && "${branch}" != "master") ]]; then
        die "Usage: force-pull-repo [-y] 'main|master'"
    fi

    if ((skip_confirm == 0)); then
        if ! confirm "Discard ALL local changes and match origin/${branch}?"; then
            die "aborted"
        fi
    fi

    log "Force-pulling ${branch} from origin"

    git fetch origin
    git reset --hard "origin/${branch}"
    git clean --force -d

    log "Force-pull complete"
}

main "$@"
