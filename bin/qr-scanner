#!/usr/bin/env bash

# QR scanner

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands flameshot zbarimg xclip notify-send

TMP_FILE="$(mktemp --suffix=.png)"
declare -r TMP_FILE

function cleanup {
    rm --force "${TMP_FILE}"
}

function main {
    local qr_content

    if ! flameshot gui --path "${TMP_FILE}" >/dev/null 2>&1; then
        return 0
    fi

    if ! qr_content="$(zbarimg --raw --quiet "${TMP_FILE}")"; then
        return 0
    fi

    printf '%s' "${qr_content}" | xclip

    if [[ -n "${qr_content}" ]]; then
        notify-send "${qr_content}"
    fi
}

main "$@"
