#!/usr/bin/env bash

set -Eeuo pipefail
shopt -s inherit_errexit

source "${HOME}/environment/lib/helpers.bash"

require_commands flameshot zbarimg xclip notify-send

TMP_FILE="$(mktemp --suffix=.png)"
declare -r TMP_FILE

function cleanup {
    rm --force "${TMP_FILE}"
}

function main {
    flameshot gui --path "${TMP_FILE}" >/dev/null 2>&1 || return 0

    local qr_content
    qr_content="$(zbarimg --raw --quiet "${TMP_FILE}")" || return 0

    printf '%s' "${qr_content}" | xclip

    if [[ -n "${qr_content}" ]]; then
        notify-send "${qr_content}"
    fi
}

main "$@"
