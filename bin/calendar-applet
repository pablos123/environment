#!/usr/bin/env bash

# Calendar applet

set -Eeuo pipefail

source "${HOME}/environment/lib/helpers.bash"

require_commands yad xdotool xclip

declare -ri CALENDAR_WIDTH=304
declare -ri CALENDAR_HEIGHT=208

function main {
    local previous_calendar=""
    if ! previous_calendar="$(xdotool search --onlyvisible --name "Tiny Calendar")"; then
        previous_calendar=""
    fi

    if [[ -n "${previous_calendar}" ]]; then
        xdotool windowclose "${previous_calendar}"
        return 0
    fi

    local -a position
    mapfile -t position < <(calculate_applet_position "${CALENDAR_WIDTH}" "${CALENDAR_HEIGHT}" | tr ' ' '\n')

    local selected_date=""
    if ! selected_date="$(yad --calendar --title="Tiny Calendar" --date-format="%d-%m-%Y" --width="${CALENDAR_WIDTH}" --height="${CALENDAR_HEIGHT}" --no-buttons --fixed --geometry="+${position[0]}+${position[1]}" 2>/dev/null)"; then
        selected_date=""
    fi

    if [[ -n "${selected_date}" ]]; then
        printf '%s' "${selected_date}" | xclip
    fi
}

main "$@"
